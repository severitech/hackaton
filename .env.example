# ==============================================================================
# Plantilla de Variables de Entorno - AgriTech / CampoIA
# Renombrar a '.env' para desarrollo local
# ==============================================================================

# --- Configuración Básica de Django ---
DEBUG=True
SECRET_KEY=django-insecure-development-only-not-for-prod-hackathon-2026
ALLOWED_HOSTS=localhost,127.0.0.1,*

# --- Base de Datos ---
# Local (Docker Compose):
DATABASE_URL=postgres://postgres:postgres@db:5432/agritech
# Producción GCP (Cloud SQL):
# DATABASE_URL=postgres://<usuario>:<password>@/agritech?host=/cloudsql/<project-id>:<location>:<instance>

# --- CORS & Seguridad ---
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=https://backend-agritech-698520637534.us-central1.run.app

# --- Google Vertex AI (Predicciones Climáticas a 12 meses) ---
GCP_PROJECT_ID=hackaton-2026-01
GCP_LOCATION=us-central1
VERTEX_AI_ENDPOINT_ID=

# --- Google Gemini (Alertas en lenguaje natural) ---
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Google Earth Engine (Datos Satelitales NDVI/NDWI) ---
# Registrarse en: https://earthengine.google.com/
GEE_PROJECT_ID=hackaton-2026-01

# --- API Climática (Open-Meteo — gratuita, sin clave) ---
OPEN_METEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive

# --- Modos de Operación ---
# False = datos simulados realistas (desarrollo sin internet)
# True  = conectar a APIs reales (producción)
USE_REAL_CLIMATE_DATA=False
USE_REAL_SATELLITE_DATA=False
USE_GEMINI_ALERTS=True

# ==============================================================================
# Asistente Culty — WhatsApp Cloud API
# ==============================================================================

# --- Meta / WhatsApp Cloud API ---
# Obtener en: https://developers.facebook.com/apps → WhatsApp → Configuración de API
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
# Token personalizado para verificar el webhook (inventalo vos, p.ej. "culty2026secret")
META_VERIFY_TOKEN=culty_verify_token
# App Secret de Meta para validar firma de webhooks (opcional pero recomendado)
META_APP_SECRET=

# --- Groq (STT Whisper + LLM Llama 3.3) ---
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# --- Texto a Voz (TTS) ---
# Opciones: 'gtts' (gratis, MVP) | 'google' (Google Cloud TTS, mejor calidad)
TTS_PROVEEDOR=gtts
# Solo requerida si TTS_PROVEEDOR=google
TTS_API_KEY=

# --- Redis + Celery (procesamiento asíncrono) ---
# Docker local: redis://redis:6379/0
# Cloud: redis://<host>:<port>/0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0

# ==============================================================================
# PASOS PARA CONFIGURAR EL WEBHOOK DE WHATSAPP
# ==============================================================================
# 1. Desplegá el backend con HTTPS (Cloud Run, ngrok para dev local).
# 2. En Meta for Developers → tu App → WhatsApp → Configuración:
#    - URL del webhook: https://<tu-dominio>/culty/whatsapp/webhook/
#    - Token de verificación: el valor de META_VERIFY_TOKEN
#    - Suscribite al evento: 'messages'
# 3. Completá META_WHATSAPP_TOKEN con el token de acceso permanente.
# 4. Completá META_WHATSAPP_PHONE_NUMBER_ID con el ID del número de WhatsApp.
# 5. Levantá Redis y el worker Celery:
#    docker-compose up redis
#    celery -A config worker -l info
# ==============================================================================
